# ─── Contact Form ────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives consultation inquiries
CONTACT_EMAIL=marius@theaxiomcollective.org

# Verified sender domain in Resend (must match your Resend domain setup)
# During development you can use: onboarding@resend.dev
RESEND_FROM=marius@theaxiomcollective.org

# ─── WhatsApp ────────────────────────────────────────────────────
# Full international number without spaces or dashes, e.g. 2348012345678
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# ─── Analytics ───────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (starts with G-)
# Leave blank to disable analytics
NEXT_PUBLIC_GA_ID=
